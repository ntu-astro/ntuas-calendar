{
	"name": "my-calendar-api",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"deploy": "wrangler deploy",
		"predeploy": "npm run build:client",
		"dev": "wrangler dev",
		"start": "wrangler dev",
		"test": "vitest",
		"test:e2e": "playwright test",
		"build:client": "tsc -p tsconfig.client.json",
		"dev:client": "tsc -p tsconfig.client.json --watch",
		"lint": "tsc --noEmit && tsc --noEmit -p tsconfig.client.json && eslint src client/src",
		"format": "prettier --write 'src/**/*.ts' 'test/**/*.ts' 'client/src/**/*.ts'",
		"format:check": "prettier --check 'src/**/*.ts' 'test/**/*.ts' 'client/src/**/*.ts'",
		"cf-typegen": "wrangler types"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.16.9",
		"@playwright/test": "^1.60.0",
		"@types/node": "^25.9.1",
		"@typescript-eslint/eslint-plugin": "^8.59.4",
		"@typescript-eslint/parser": "^8.59.4",
		"eslint": "^10.4.0",
		"prettier": "^3.8.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.7",
		"wrangler": "^4.94.0"
	}
}
