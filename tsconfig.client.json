{
	"compilerOptions": {
		"target": "es2022",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"strict": true,
		"noEmit": false,
		"outDir": "public/dist",
		"rootDir": "client/src",
		"sourceMap": true,
		"declaration": false,
		"skipLibCheck": true,
		"isolatedModules": true,
		"forceConsistentCasingInFileNames": true,
		"useDefineForClassFields": true
	},
	"include": ["client/src/**/*.ts"],
	"exclude": ["node_modules"]
}
